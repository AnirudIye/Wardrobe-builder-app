# Copy to .env and fill in. NEVER commit the real .env.

# --- Core ---
# "dev" (default) or "production". Production refuses to start with a weak
# JWT_SECRET or missing CORS_ORIGINS, disables /docs, and enables HSTS.
ENVIRONMENT=dev

# For local dev, SQLite is used by default. For managed Postgres:
#   Neon:      DATABASE_URL=postgresql+psycopg://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
#   Supabase:  use the SESSION pooler (port 5432) or direct connection, NOT the
#              transaction pooler (6543) - psycopg3 prepared statements break under it.
DATABASE_URL=sqlite:///./wardrobe.db

# Secret used to sign JWTs. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-me-to-a-long-random-string
# 10080 = 7 days (dev default). For production, 4320 (3 days) is a saner cap -
# there is no refresh-token flow, so shorter simply logs users out sooner.
JWT_EXPIRE_MINUTES=10080

# --- Security ---
# Comma-separated allowed browser origins, e.g. https://app.example.com
# REQUIRED when ENVIRONMENT=production. Dev falls back to FRONTEND_BASE_URL.
CORS_ORIGINS=
# Per-IP throttling on /auth/* endpoints (leave on; tests disable it themselves)
RATE_LIMIT_ENABLED=true
# Per-account login lockout (shares the switch above): after this many failed
# password attempts within the window, login refuses even the correct password.
LOGIN_LOCKOUT_ATTEMPTS=8
LOGIN_LOCKOUT_MINUTES=15

# --- Media storage ---
# "local" (default: files under MEDIA_DIR served at /media) or "s3"
# (any S3-compatible store, including Cloudflare R2).
STORAGE_BACKEND=local
# Where uploaded garment images are stored on disk (local storage backend)
MEDIA_DIR=./media
# Public base URL the frontend uses to load images/served files
PUBLIC_BASE_URL=http://localhost:8000
# s3 backend settings (all required when STORAGE_BACKEND=s3):
S3_BUCKET=
# R2: https://<account_id>.r2.cloudflarestorage.com  (leave empty for AWS S3)
S3_ENDPOINT_URL=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Public base for object URLs, e.g. https://pub-xxxx.r2.dev or a CDN domain
S3_PUBLIC_BASE_URL=

# --- AI (Anthropic Claude) ---
ANTHROPIC_API_KEY=sk-ant-...
# Cheapest capable model per call site; escalate only if quality is insufficient.
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Weather (OpenWeatherMap) ---
OPENWEATHER_API_KEY=

# --- Shopping (SerpAPI Google Shopping) ---
SERPAPI_KEY=

# --- AI (Google Gemini) ---
# Powers TryOn image generation, and ALL text AI features (tagging, outfit &
# buy-next reasoning, trends, DresserAI chat) when no Anthropic key is set.
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_IMAGE_MODEL=gemini-2.5-flash-image
GOOGLE_TEXT_MODEL=gemini-flash-lite-latest

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Price ID for the $5/month subscription (create in Stripe dashboard, test mode)
STRIPE_PRICE_ID=price_...
# Where Stripe redirects after checkout / portal
FRONTEND_BASE_URL=http://localhost:5173

# --- Sign in with Google (optional) ---
# console.cloud.google.com -> APIs & Services -> Credentials -> Create
# credentials -> OAuth client ID -> Web application. Add your frontend origin
# (http://localhost:5173 for dev) under "Authorized JavaScript origins".
# No client secret needed (ID-token flow). Unset = button hidden.
GOOGLE_OAUTH_CLIENT_ID=

# --- Quota ---
FREE_DAILY_RECOMMENDATION_LIMIT=5
FREE_WEEKLY_CHAT_LIMIT=20
FREE_WEEKLY_TRYON_LIMIT=5

# --- Email (signup confirmation + password reset) ---
# All optional. When unset, email verification is skipped (new users are
# auto-verified) so the app still runs with no mail server.
# BREVO_API_KEY is preferred when set: sends via Brevo's HTTP API, which works
# on hosts that block outbound SMTP (e.g. Render's free tier). SMTP_FROM must
# then be a sender address verified in Brevo.
BREVO_API_KEY=
# SMTP fallback (used when no Brevo key). For Gmail use an App Password; for
# local testing, Mailtrap works well.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# From header, e.g. "BetterDresser <no-reply@yourdomain.com>"
SMTP_FROM=
SMTP_STARTTLS=true
EMAIL_VERIFY_EXPIRE_MINUTES=1440
